{
  "info": {
    "_postman_id": "hityam-rental-api-v2",
    "name": "Hityam Rental API (User + Admin)",
    "description": "Unified backend for Hityam Rental User App and Admin App",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "carId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "User App",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Register",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+1234567890\",\n  \"password\": \"password123\"\n}" },
                "url": "{{baseUrl}}/api/auth/register"
              }
            },
            {
              "name": "Verify Registration",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+1234567890\",\n  \"otp\": \"123456\"\n}" },
                "url": "{{baseUrl}}/api/auth/verify-registration"
              }
            },
            {
              "name": "Login",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@hityam.com\",\n  \"password\": \"user12345\"\n}" },
                "url": "{{baseUrl}}/api/auth/login"
              }
            },
            {
              "name": "Send OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+1234567890\"\n}" },
                "url": "{{baseUrl}}/api/auth/otp/send"
              }
            },
            {
              "name": "Login with OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+1234567890\",\n  \"otp\": \"123456\"\n}" },
                "url": "{{baseUrl}}/api/auth/login-with-otp"
              }
            },
            {
              "name": "Forgot Password - Send OTP",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+10000000002\"\n}" },
                "url": "{{baseUrl}}/api/auth/forgot-password/send-otp"
              }
            },
            {
              "name": "Forgot Password - Send OTP (alias)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+10000000002\"\n}" },
                "url": "{{baseUrl}}/api/auth/forgot-password"
              }
            },
            {
              "name": "Forgot Password - Reset",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+10000000002\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"newpassword99\"\n}" },
                "url": "{{baseUrl}}/api/auth/forgot-password/reset"
              }
            },
            {
              "name": "Reset Password (alias)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"+10000000002\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"newpassword99\"\n}" },
                "url": "{{baseUrl}}/api/auth/reset-password"
              }
            }
          ]
        },
        {
          "name": "Home",
          "item": [
            {
              "name": "Get Home Feed",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/home/feed"
              }
            }
          ]
        },
        {
          "name": "Cars",
          "item": [
            {
              "name": "List Cars",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/cars?search=tesla&type=SUV" }
            },
            {
              "name": "Nearby Cars",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/cars/nearby?lat=40.730610&lng=-73.935242&maxDistance=50000" }
            },
            {
              "name": "Car Detail",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/cars/{{carId}}" }
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "Get Me",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/users/me"
              }
            },
            {
              "name": "Toggle Favorite",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"carId\": \"{{carId}}\"\n}" },
                "url": "{{baseUrl}}/api/users/me/favorites"
              }
            },
            {
              "name": "Referrals",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/users/me/referrals"
              }
            },
            {
              "name": "Static Pages",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/users/static-pages" }
            }
          ]
        },
        {
          "name": "Bookings",
          "item": [
            {
              "name": "Create Booking",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"carId\": \"{{carId}}\",\n  \"startDate\": \"2026-06-15T10:00:00Z\",\n  \"endDate\": \"2026-06-18T10:00:00Z\",\n  \"pickupLocation\": \"Manhattan Hub\",\n  \"dropoffLocation\": \"Manhattan Hub\"\n}" },
                "url": "{{baseUrl}}/api/bookings"
              }
            },
            {
              "name": "My Trips",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/bookings/my-trips"
              }
            },
            {
              "name": "Booking Detail",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
              }
            },
            {
              "name": "Cancel Booking",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel"
              }
            }
          ]
        },
        {
          "name": "Host (My Fleet)",
          "item": [
            {
              "name": "Dashboard",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/host/dashboard"
              }
            },
            {
              "name": "Listings",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/host/listings?status=all"
              }
            },
            {
              "name": "Create Listing",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "name", "value": "My Car", "type": "text" },
                    { "key": "brand", "value": "Toyota", "type": "text" },
                    { "key": "type", "value": "Sedan", "type": "text" },
                    { "key": "pricePerDay", "value": "75", "type": "text" },
                    { "key": "images", "type": "file", "src": [] }
                  ]
                },
                "url": "{{baseUrl}}/api/host/listings"
              }
            },
            {
              "name": "Car Documents",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/host/cars/{{carId}}/documents"
              }
            }
          ]
        },
        {
          "name": "Payments",
          "item": [
            {
              "name": "Create Payment",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"paymentMethod\": \"card\"\n}" },
                "url": "{{baseUrl}}/api/payments"
              }
            }
          ]
        },
        {
          "name": "Reviews",
          "item": [
            {
              "name": "Create Review",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"carId\": \"{{carId}}\",\n  \"bookingId\": \"{{bookingId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great car!\"\n}" },
                "url": "{{baseUrl}}/api/reviews"
              }
            },
            {
              "name": "Car Reviews",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/reviews/car/{{carId}}" }
            }
          ]
        },
        {
          "name": "360 Viewer",
          "item": [
            {
              "name": "Get Spin Data (User)",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/user/viewer360/{{carId}}" }
            },
            {
              "name": "Get WebView URL",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/user/viewer360/{{carId}}/url" }
            },
            {
              "name": "Legacy Spin Data",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/viewer360/{{carId}}" }
            },
            {
              "name": "Open HTML Viewer (WebView)",
              "request": { "method": "GET", "url": "{{baseUrl}}/viewer360/{{carId}}" }
            },
            {
              "name": "Host Upload 360 Video",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "body": { "mode": "formdata", "formdata": [{ "key": "video", "type": "file", "src": [] }] },
                "url": "{{baseUrl}}/api/host/cars/{{carId}}/viewer360/upload"
              }
            }
          ]
        },
        {
          "name": "AI Concierge",
          "item": [
            {
              "name": "Chat",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"message\": \"Which SUV is best for 7 people?\",\n  \"context\": { \"location\": \"New York\" }\n}" },
                "url": "{{baseUrl}}/api/ai/chat"
              }
            },
            {
              "name": "Recommendations",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
                "url": "{{baseUrl}}/api/ai/recommendations"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin App",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Admin Login",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@hityam.com\",\n  \"password\": \"admin12345\"\n}" },
                "url": "{{baseUrl}}/api/auth/login"
              }
            }
          ]
        },
        {
          "name": "Dashboard",
          "item": [
            {
              "name": "Stats",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/dashboard/stats"
              }
            },
            {
              "name": "Insights",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/dashboard/insights"
              }
            }
          ]
        },
        {
          "name": "Cars",
          "item": [
            {
              "name": "List Cars",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/cars?status=Available"
              }
            },
            {
              "name": "Create Car",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"Model S\",\n  \"brand\": \"Tesla\",\n  \"type\": \"Sedan\",\n  \"category\": \"Sedan\",\n  \"pricePerDay\": 120,\n  \"fuelType\": \"Electric\",\n  \"transmission\": \"Automatic\",\n  \"seatingCapacity\": 5,\n  \"images\": [\"https://example.com/tesla.jpg\"],\n  \"location\": { \"type\": \"Point\", \"coordinates\": [-73.935242, 40.730610] },\n  \"locationLabel\": \"Manhattan Hub\"\n}" },
                "url": "{{baseUrl}}/api/admin/cars"
              }
            },
            {
              "name": "Update Car",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"pricePerDay\": 130,\n  \"status\": \"Available\"\n}" },
                "url": "{{baseUrl}}/api/admin/cars/{{carId}}"
              }
            },
            {
              "name": "Delete Car",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/cars/{{carId}}"
              }
            },
            {
              "name": "Car Documents",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/cars/{{carId}}/documents"
              }
            },
            {
              "name": "Refresh AI Predictions",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/cars/ai-predictions/refresh-all"
              }
            }
          ]
        },
        {
          "name": "Bookings",
          "item": [
            {
              "name": "List All Bookings",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/bookings"
              }
            },
            {
              "name": "Booking Detail",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/bookings/{{bookingId}}"
              }
            },
            {
              "name": "Approve Booking",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"status\": \"Approve\"\n}" },
                "url": "{{baseUrl}}/api/admin/bookings/{{bookingId}}/status"
              }
            },
            {
              "name": "Decline Booking",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"status\": \"Decline\"\n}" },
                "url": "{{baseUrl}}/api/admin/bookings/{{bookingId}}/status"
              }
            }
          ]
        },
        {
          "name": "People",
          "item": [
            {
              "name": "List Clients",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/clients"
              }
            },
            {
              "name": "Client Detail",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/clients/CLIENT_ID"
              }
            },
            {
              "name": "List Staff",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/staff"
              }
            },
            {
              "name": "Staff Payout",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"staffId\": \"STAFF_ID\",\n  \"amount\": 500,\n  \"type\": \"Payout\"\n}" },
                "url": "{{baseUrl}}/api/admin/staff/payout"
              }
            }
          ]
        },
        {
          "name": "Revenue",
          "item": [
            {
              "name": "Revenue Analytics",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/revenue"
              }
            },
            {
              "name": "Legacy Revenue Analytics",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/analytics/revenue"
              }
            }
          ]
        },
        {
          "name": "AI Assistant",
          "item": [
            {
              "name": "Get Config",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/ai/config"
              }
            },
            {
              "name": "Chat",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"message\": \"Summarize today's revenue and fleet utilization\"\n}" },
                "url": "{{baseUrl}}/api/admin/ai/chat"
              }
            }
          ]
        },
        {
          "name": "Viewer 360",
          "item": [
            {
              "name": "Upload 360 Video",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "body": { "mode": "formdata", "formdata": [{ "key": "video", "type": "file", "src": [] }] },
                "url": "{{baseUrl}}/api/admin/cars/{{carId}}/viewer360/upload"
              }
            },
            {
              "name": "Get Spin JSON",
              "request": { "method": "GET", "url": "{{baseUrl}}/api/viewer360/{{carId}}" }
            }
          ]
        }
      ]
    }
  ]
}
